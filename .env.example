# ─── COPY THIS FILE TO .env AND FILL IN ALL VALUES ───────────────────────────
# Never commit .env to source control.

# ─── Application ──────────────────────────────────────────────────────────────
# Public URL of this deployment (no trailing slash)
NEXT_PUBLIC_APP_URL=https://msp.yourdomain.com

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=msp_platform
POSTGRES_USER=msp_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
# Automatically composed by docker-compose — do not change this line
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
# Automatically composed by docker-compose — do not change this line
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256 key for encrypting API keys, TOTP secrets, SMTP passwords stored in DB
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# These are the DEFAULTS — the MSP can override in the admin settings UI
SMTP_HOST=smtp.yourmailserver.com
SMTP_PORT=587
SMTP_USER=notifications@yourdomain.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_NAME=Your MSP Name
SMTP_FROM_ADDRESS=notifications@yourdomain.com

# IMAP (for inbound email parsing — approval replies etc.)
IMAP_HOST=imap.yourmailserver.com
IMAP_PORT=993
IMAP_USER=notifications@yourdomain.com
IMAP_PASSWORD=CHANGE_ME

# ─── Backup ───────────────────────────────────────────────────────────────────
# Retention period in days (default 365)
BACKUP_RETENTION_DAYS=365
# Cron schedule for backups (default: 2am daily)
BACKUP_SCHEDULE=0 2 * * *

# ─── Integrations (configured in admin UI — these are optional env fallbacks) ─
# Atera API key — also configurable in admin settings
ATERA_API_KEY=

# Unifi Site Manager credentials — also configurable in admin settings
UNIFI_USERNAME=
UNIFI_PASSWORD=
UNIFI_MFA_CODE=

# UISP self-hosted base URL — also configurable in admin settings
UISP_BASE_URL=
UISP_API_KEY=

# ─── Puppeteer (PDF generation) ───────────────────────────────────────────────
# Path to Chromium inside the Docker container (set by Dockerfile)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Max login attempts before lockout
LOGIN_MAX_ATTEMPTS=5
# Lockout duration in seconds
LOGIN_LOCKOUT_SECONDS=900

# ─── Session ──────────────────────────────────────────────────────────────────
# Session max age in seconds (default: 8 hours)
SESSION_MAX_AGE=28800
